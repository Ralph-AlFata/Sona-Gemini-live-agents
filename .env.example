# Root .env — shared by all three Python services (session, drawing, orchestrator).
# Copy to .env and fill in your values. Never commit .env to git.
#
# Frontend has its own env file: see frontend/.env.example → copy to frontend/.env.local

# ════════════════════════════════════════════════════════════════════════════════
# SESSION SERVICE (services/session)
# ════════════════════════════════════════════════════════════════════════════════

# GCP project (required for Firestore + Cloud Storage)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Firestore
USE_FIRESTORE=false           # set to true in production
FIRESTORE_DATABASE=(default)

# Cloud Storage bucket for canvas snapshots
GCS_BUCKET=sona-canvases-your-suffix

# Auth
SESSION_AUTH_ENABLED=false
# SESSION_AUTH_AUDIENCE=your-firebase-project-id   # required if SESSION_AUTH_ENABLED=true

# ════════════════════════════════════════════════════════════════════════════════
# DRAWING SERVICE (services/drawing)
# ════════════════════════════════════════════════════════════════════════════════

# URL of the session service (for token validation)
SESSION_SERVICE_URL=http://localhost:8003

# Auth
DRAWING_AUTH_ENABLED=false
# DRAWING_AUTH_AUDIENCE=your-firebase-project-id   # required if DRAWING_AUTH_ENABLED=true

# ════════════════════════════════════════════════════════════════════════════════
# ORCHESTRATOR SERVICE (services/orchestrator)
# ════════════════════════════════════════════════════════════════════════════════

# Gemini — Option A: Vertex AI (recommended on GCP, uses your gcloud credentials)
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_LOCATION=us-central1

# Gemini — Option B: API key (easier for local dev without GCP auth)
# GOOGLE_GENAI_USE_VERTEXAI=false
# GOOGLE_API_KEY=your-gemini-api-key-from-ai-studio

# Downstream service URLs
DRAWING_SERVICE_URL=http://localhost:8002

# Auth
ORCHESTRATOR_AUTH_ENABLED=false
# ORCHESTRATOR_AUTH_AUDIENCE=your-firebase-project-id   # required if ORCHESTRATOR_AUTH_ENABLED=true

# ════════════════════════════════════════════════════════════════════════════════
# SHARED — applies to all three Python services
# ════════════════════════════════════════════════════════════════════════════════

# Allowed CORS origin (set to your frontend URL)
FRONTEND_URL=http://localhost:3000
VITE_FIREBASE_API_KEY=
VITE_SESSION_HTTP_BASE=
