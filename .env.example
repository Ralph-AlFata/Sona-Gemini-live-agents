# ─── Google Cloud ─────────────────────────────────────────────────────────────
GOOGLE_API_KEY=
GOOGLE_CLOUD_PROJECT=
GOOGLE_GENAI_USE_VERTEXAI=false

# ─── Firestore + Storage (session service) ───────────────────────────────────
FIRESTORE_DATABASE=(default)
USE_FIRESTORE=false
GCS_BUCKET=sona-canvases
SESSION_AUTH_ENABLED=true
# Optional audience/client-id check for tokens
SESSION_AUTH_AUDIENCE=
ORCHESTRATOR_AUTH_ENABLED=false
# Optional audience check for Firebase token verification in orchestrator
ORCHESTRATOR_AUTH_AUDIENCE=
DRAWING_AUTH_ENABLED=false
# Optional audience check for Firebase token verification in drawing service
DRAWING_AUTH_AUDIENCE=

# ─── Inter-service URLs (used by orchestrator) ───────────────────────────────
DRAWING_SERVICE_URL=http://drawing:8002
SESSION_SERVICE_URL=http://session:8003

# ─── Frontend origin (CORS for all FastAPI services) ─────────────────────────
FRONTEND_URL=http://localhost:3000
VITE_FIREBASE_API_KEY=
VITE_SESSION_HTTP_BASE=
