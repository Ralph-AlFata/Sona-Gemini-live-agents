# Frontend — copy to .env.local and fill in values
# All VITE_* vars are baked into the static build at compile time

# Firebase Web API key (from Firebase Console → Project Settings → General)
VITE_FIREBASE_API_KEY=your-firebase-web-api-key

# Backend service base URLs
VITE_SESSION_HTTP_BASE=http://localhost:8003
VITE_DRAWING_HTTP_BASE=http://localhost:8002
VITE_DRAWING_WS_BASE=ws://localhost:8002
VITE_ORCHESTRATOR_WS_BASE=ws://localhost:8001
